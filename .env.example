# StatEdu local environment template (safe to commit)

# LLM
STATEDU_LLM_PROVIDER=openai
OPENAI_API_KEY=PASTE_YOUR_OPENAI_KEY
STATEDU_OPENAI_MODEL=gpt-4.1-mini

# Research stack
STATEDU_WEB_RESEARCH_ENABLED=1
STATEDU_WEB_RESEARCH_PROVIDER=auto
STATEDU_WEB_RESEARCH_MAX_RESULTS=6
STATEDU_WEB_RESEARCH_TIMEOUT_SEC=10
STATEDU_TAVILY_API_KEY=
STATEDU_SERPAPI_API_KEY=
STATEDU_YOUTUBE_API_KEY=
STATEDU_WEB_RESEARCH_PREFERRED_DOMAINS=khanacademy.org,statquest.org,youtube.com,openstax.org,wikipedia.org

# Video style cues
STATEDU_VIDEO_RESEARCH_ENABLED=1
STATEDU_VIDEO_RESEARCH_MAX_RESULTS=3

# Image stage
STATEDU_IMAGE_GENERATION_ENABLED=1
STATEDU_IMAGE_PROVIDER=openai
STATEDU_OPENAI_IMAGE_MODEL=gpt-image-1
STATEDU_OPENAI_IMAGE_SIZE=1536x1024
